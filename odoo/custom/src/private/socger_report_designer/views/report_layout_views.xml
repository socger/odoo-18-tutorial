<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Form View -->
    <record id="report_layout_view_form" model="ir.ui.view">
        <field name="name">report.designer.layout.form</field>
        <field name="model">report.designer.layout</field>
        <field name="arch" type="xml">
            <form string="Report Layout">
                <header>
                    <button
                        name="action_publish"
                        string="Publish"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'draft'"
                    />
                    <button
                        name="action_unpublish"
                        string="Unpublish"
                        type="object"
                        invisible="state != 'published'"
                    />
                    <button
                        name="action_preview"
                        string="Preview"
                        type="object"
                        class="btn-secondary"
                        invisible="state != 'published'"
                    />
                    <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="draft,published"
                    />
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="action_open_designer"
                            string="Open Designer"
                            type="object"
                            class="oe_highlight"
                            icon="fa-paint-brush"
                        />
                    </div>
                    <widget
                        name="web_ribbon"
                        title="Archived"
                        bg_color="bg-danger"
                        invisible="active"
                    />
                    <div class="oe_title">
                        <label for="name" />
                        <h1>
                            <field name="name" placeholder="Report name..." />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="target_model" />
                            <field name="description" />
                            <field
                                name="company_id"
                                groups="base.group_multi_company"
                            />
                        </group>
                        <group>
                            <field name="paper_format" />
                            <field name="paper_orientation" />
                            <field name="paper_format_id" />
                            <field name="version" />
                            <field name="element_count" readonly="1" />
                        </group>
                    </group>
                    <notebook>
                        <page string="Layout Data" name="layout">
                            <field name="layout_json" />
                        </page>
                        <page string="Published Report" name="published">
                            <group>
                                <field name="qweb_template_id" readonly="1" />
                                <field name="report_action_id" readonly="1" />
                                <field name="last_publish_date" readonly="1" />
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" />
                    <field name="activity_ids" />
                    <field name="message_ids" />
                </div>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="report_layout_view_tree" model="ir.ui.view">
        <field name="name">report.designer.layout.tree</field>
        <field name="model">report.designer.layout</field>
        <field name="arch" type="xml">
            <list multi_edit="1">
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="target_model" />
                <field
                    name="state"
                    widget="badge"
                    decoration-success="state == 'published'"
                    decoration-info="state == 'draft'"
                />
                <field name="version" />
                <field name="element_count" />
                <field name="last_publish_date" />
                <field
                    name="company_id"
                    groups="base.group_multi_company"
                    optional="hide"
                />
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="report_layout_view_search" model="ir.ui.view">
        <field name="name">report.designer.layout.search</field>
        <field name="model">report.designer.layout</field>
        <field name="arch" type="xml">
            <search string="Report Layouts">
                <field name="name" />
                <field name="target_model" />
                <separator />
                <filter
                    string="Draft"
                    name="draft"
                    domain="[('state', '=', 'draft')]"
                />
                <filter
                    string="Published"
                    name="published"
                    domain="[('state', '=', 'published')]"
                />
                <separator />
                <filter
                    string="Archived"
                    name="inactive"
                    domain="[('active', '=', False)]"
                />
                <group expand="0" string="Group By">
                    <filter
                        string="Status"
                        name="group_state"
                        context="{'group_by': 'state'}"
                    />
                    <filter
                        string="Target Model"
                        name="group_model"
                        context="{'group_by': 'target_model'}"
                    />
                    <filter
                        string="Company"
                        name="group_company"
                        context="{'group_by': 'company_id'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="report_layout_action" model="ir.actions.act_window">
        <field name="name">Report Layouts</field>
        <field name="res_model">report.designer.layout</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_published': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first report layout
            </p>
            <p>
                Design visual reports using the drag &amp; drop builder.
            </p>
        </field>
    </record>
</odoo>
