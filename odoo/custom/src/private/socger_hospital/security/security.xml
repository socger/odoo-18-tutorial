<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="module_category_hospital" model="ir.module.category">
        <field name="name">Hospital app</field>
        <field name="sequence">1</field>
    </record>

    <record id="group_hospital_receptionists" model="res.groups">
        <field name="name">Receptionists</field>
        <field name="category_id" ref="socger_hospital.module_category_hospital" />
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]" />
        <field name="comment">this user will have access to appointments.</field>
    </record>

    <record id="group_hospital_doctors" model="res.groups">
        <field name="name">Doctors</field>
        <field name="category_id" ref="socger_hospital.module_category_hospital" />
        <field
            name="implied_ids"
            eval="[(4, ref('socger_hospital.group_hospital_receptionists'))]"
        />
        <field name="comment">this user will have access to patient details.</field>
    </record>

    <!-- ================ -->
    <!-- | RECORD RULES |-->
    <!-- ================ -->
    <!-- El usuario logueado sólo podrá ver citas creadas por él mismo.
         Da igual que tenga privilegios de doctor o de recepcionista. -->
    <record id="receptionist_own_appointment_rule" model="ir.rule">
        <field name="name">receptionist: view own records</field>
        <field name="model_id" ref="model_hospital_appointment" />
        <!-- <field eval="False" name="global"/> -->
        <field
            name="groups"
            eval="[Command.set([ref('socger_hospital.group_hospital_receptionists')])]"
        />

        <field name="domain_force">[('create_uid','=', user.id)]</field>
    </record>

    <record id="doctor_view_all_appointment_rule" model="ir.rule">
        <field name="name">doctor: view all records</field>
        <field name="model_id" ref="model_hospital_appointment" />
        <!-- <field eval="False" name="global"/> -->
        <field
            name="groups"
            eval="[Command.set([ref('socger_hospital.group_hospital_doctors')])]"
        />

        <field name="domain_force">[]</field>
    </record>
</odoo>
