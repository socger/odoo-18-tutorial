<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_hospital_appointment_list" model="ir.ui.view">
        <field name="name">hospital.appointment.list</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <list string="Appointments">
                <field name="reference" />
                <field name="patient_id" />
                <field
                    name="create_uid"
                    groups="socger_hospital.group_hospital_doctors"
                />
                <field name="date_appointment" optional="show" />
            </list>
        </field>
    </record>

    <record id="view_hospital_appointment_form" model="ir.ui.view">
        <field name="name">hospital.appointment.form</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <form string="Appointment">
                <header>
                    <button
                        name="action_confirm"
                        type="object"
                        string="Confirm"
                        invisible="state not in ('draft')"
                        class="btn-primary"
                    />
                    <button
                        name="action_ongoing"
                        type="object"
                        string="Ongoing"
                        invisible="state not in ('confirmed')"
                        class="btn-primary"
                    />
                    <button
                        name="action_done"
                        type="object"
                        string="Done"
                        invisible="state not in ('ongoing')"
                        class="btn-primary"
                    />
                    <button
                        name="action_cancelled"
                        type="object"
                        string="Cancelled"
                        invisible="state in ('done')"
                    />
                    <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="draft,confirmed,ongoing,done"
                    />
                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="reference" readonly="True" />
                            <field name="patient_id" />
                            <field
                                name="date_of_birth"
                                groups="socger_hospital.group_hospital_doctors"
                            />
                            <field name="date_appointment" optional="show" />
                        </group>
                        <group>
                            <field name="note" />
                            <field name="total_qty" />
                            <field
                                name="create_uid"
                                groups="socger_hospital.group_hospital_doctors"
                            />
                        </group>
                    </group>

                    <notebook>
                        <page name="appointment_lines" string="Lines">
                            <field name="appointment_line_ids">
                                <list editable="bottom">
                                    <field name="product_id" />
                                    <field name="qty" />
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <field name="product_id" />
                                            <field name="qty" />
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page name="other_info" string="Other info">
                            <group>
                                <field name="additional_note" />
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter reload_on_post="True" />
            </form>
        </field>
    </record>

    <record id="view_hospital_appointment_search" model="ir.ui.view">
        <field name="name">hospital.appointment.search</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <search string="Appointments">
                <field
                    name="reference"
                    filter_domain="['|', ('reference', 'ilike', self), ('patient_id', 'ilike', self)]"
                    string="Joined Filter"
                />
                <field name="reference" />
                <field name="patient_id" />

                <group expand="1" string="Group By">
                    <filter
                        name="group_by_patient"
                        string="Patient"
                        context="{'group_by' : 'patient_id'}"
                    />
                </group>

                <searchpanel>
                    <field name="patient_id" string="Patient" enable_counters="1" />
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="action_hospital_appointment" model="ir.actions.act_window">
        <field name="name">Appointments</field>
        <field name="res_model">hospital.appointment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hospital_appointment_search" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new appointment
            </p>
        </field>
    </record>
</odoo>
