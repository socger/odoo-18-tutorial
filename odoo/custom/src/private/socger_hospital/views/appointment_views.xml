<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hospital_appointment_list" model="ir.ui.view">
        <field name="name">hospital.appointment.list</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <list string="Appointments">
                <field name="reference" />
                <field name="patient_id" />
                <field name="date_appointment" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_hospital_appointment_form" model="ir.ui.view">
        <field name="name">hospital.appointment.form</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <form string="Appointment">
                <header>
                <!-- Con options="{'clickable': '1'}" hacemos que el estado sea clickeable, es decir, que podamos cambiarlo desde la vista de formulario.
                     Pero vamos a usar botones en la vista de formulario para cambiar el estado, por lo que no necesitamos que sea clickeable.

                    <field name="state"
                           widget="statusbar"
                           options="{'clickable': '1'}"
                    />
                -->
                    <!-- buttons -->
                    <button name="action_confirm"
                            type="object"
                            string="Confirm"
                            invisible="state not in ('draft')"
                            class="btn-primary"
                    />
                    <button name="action_ongoing"
                            type="object"
                            string="Ongoing"
                            invisible="state not in ('confirmed')"
                            class="btn-primary"
                    />
                    <button name="action_done"
                            type="object"
                            string="Done"
                            invisible="state not in ('ongoing')"
                            class="btn-primary"
                    />
                    <button name="action_cancelled"
                            type="object"
                            string="Cancelled"
                            invisible="state in ('done')"
                    />

                    <!-- statusbar -->
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,confirmed,ongoing,done"
                    />
                </header>

                <sheet>
                    <sheet>
                        <group>
                            <group>
                                <field name="reference" readonly="True"/>
                                <field name="patient_id" />
                                <field name="date_of_birth"/>
                                <field name="date_appointment" optional="show"/>
                            </group>
                            <group>
                                <field name="note" />
                                <field name="total_qty"/>
                            </group>
                        </group>

                        <notebook>
                            <page name="appointment_lines" string="Lines">
                                <field name="appointment_line_ids">
                                    <!-- <tree string="Appointment lines" editable="bottom"> -->
                                    <list editable="bottom">
                                        <field name="product_id" />
                                        <field name="qty" />
                                    </list>
                                    <form>
                                        <sheet>
                                            <group>
                                                <field name="product_id" />
                                                <field name="qty" />
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                                <!-- <field name="appointment_line_ids"/> -->
                            </page>
                            <page name="other_info" string="Other info">
                                <group>
                                    <field name="aditional_note"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>

                    <br/>

                    <sheet>
                        <chatter reload_on_post="True"/>
                        <!-- <chatter/> -->
                    </sheet>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hospital_appointment" model="ir.actions.act_window">
        <field name="name">Appointments</field>
        <field name="res_model">hospital.appointment</field>
        <field name="view_mode">list,form,kanban</field>

<!-- Sólo tenemos una vista de lista y una vista de formulario, por lo que no necesitamos el campo view_ids
        <field name="view_ids"
            eval="[Command.clear(),
                (0,0,{'view_mode':'list', 'view_id': ref('view_hospital_patient_list')}),
                (0,0,{'view_mode':'form', 'view_id': ref('view_hospital_patient_form')})]"
        />
 -->

        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new appointment
            </p>
        </field>
    </record>
</odoo>
