<?xml version="1.0" encoding="utf-8" ?>
<odoo noupdate="1">
    <!-- con noupdate="1" permitimos que los datos se actualicen en las actualizaciones
         del módulo, pero no se borren si el módulo se desinstala.
         Esto es útil para secuencias, subtipos de mensajes, etc. -->

    <!-- Sequences for appointment -->
    <record id="seq_hospital_appointment" model="ir.sequence">
        <field name="name">Appointment reference</field>
        <field name="code">hospital.appointment.sequence</field>
        <field name="prefix">HP</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False" />
    </record>
</odoo>
