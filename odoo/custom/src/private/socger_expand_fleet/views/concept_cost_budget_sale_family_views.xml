<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_concept_cost_budget_sale_family_list" model="ir.ui.view">
        <field name="name">concept.cost.budget.sale.family.list</field>
        <field name="model">concept.cost.budget.sale.family</field>
        <field name="arch" type="xml">
            <list string="Concept Families">
                <field name="name" />
                <field name="description" />
            </list>
        </field>
    </record>

    <record id="view_concept_cost_budget_sale_family_form" model="ir.ui.view">
        <field name="name">concept.cost.budget.sale.family.form</field>
        <field name="model">concept.cost.budget.sale.family</field>
        <field name="arch" type="xml">
            <form string="Concept Family">
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="description" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_concept_cost_budget_sale_family_search" model="ir.ui.view">
        <field name="name">concept.cost.budget.sale.family.search</field>
        <field name="model">concept.cost.budget.sale.family</field>
        <field name="arch" type="xml">
            <search string="Concept Families">
                <field name="name" />
                <field name="description" />
            </search>
        </field>
    </record>

    <record id="action_concept_cost_budget_sale_family" model="ir.actions.act_window">
        <field
            name="name"
        >Familias - Conceptos de control de costes, presupuestos ó ventas</field>
        <field name="res_model">concept.cost.budget.sale.family</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new concept family
            </p>
        </field>
    </record>
</odoo>
