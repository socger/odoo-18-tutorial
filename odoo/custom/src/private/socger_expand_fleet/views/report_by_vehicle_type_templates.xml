<odoo>
    <template id="report_concept_cost_budget_sale_by_vehicle_type_document">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h3
                    >Por tipo vehículo - Conceptos de control de costes, presupuestos ó ventas</h3>
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Tipo de vehículo</th>
                                <th>Concepto</th>
                                <th class="text-end">Valor</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="rec">
                                <tr>
                                    <td>
                                        <span t-field="rec.vehicle_type_id" />
                                    </td>
                                    <td>
                                        <span
                                            t-field="rec.concept_cost_budget_sale_id"
                                        />
                                    </td>
                                    <td class="text-end">
                                        <span t-field="rec.value" />
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
