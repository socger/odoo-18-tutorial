<odoo>
    <record id="paperformat_no_header" model="report.paperformat">
        <field name="name">A4 sin cabecera</field>
        <field name="default" eval="False" />
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">20</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False" />
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="report_concept_cost_budget_sale_family" model="ir.actions.report">
        <field
            name="name"
        >Categorías - Conceptos de control de costes, presupuestos ó ventas</field>
        <field name="model">concept.cost.budget.sale.family</field>
        <field name="report_type">qweb-pdf</field>

        <field
            name="report_name"
        >socger_expand_fleet.report_concept_cost_budget_sale_family_document</field>
        <field
            name="report_file"
        >socger_expand_fleet.report_concept_cost_budget_sale_family_document</field>

        <field
            name="print_report_name"
        >'Categorías - Conceptos de control de costes, presupuestos ó ventas'</field>
        <field name="binding_model_id" ref="model_concept_cost_budget_sale_family" />
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro" />
    </record>

    <record id="report_concept_cost_budget_sale_family_basic" model="ir.actions.report">
        <field name="name">Categorías - Conceptos (sin cabecera)</field>
        <field name="model">concept.cost.budget.sale.family</field>
        <field name="report_type">qweb-pdf</field>
        <field
            name="report_name"
        >socger_expand_fleet.report_concept_cost_budget_sale_family_basic_document</field>
        <field
            name="report_file"
        >socger_expand_fleet.report_concept_cost_budget_sale_family_basic_document</field>
        <field name="print_report_name">'Categorías - Conceptos (sin cabecera)'</field>
        <field name="binding_model_id" ref="model_concept_cost_budget_sale_family" />
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_no_header" />
    </record>
</odoo>
