<odoo>
    <template id="report_concept_cost_budget_sale_family_document">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h3
                    >Categorías - Conceptos de control de costes, presupuestos ó ventas</h3>
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Categoría</th>
                                <th>Descripción</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="rec">
                                <tr>
                                    <td>
                                        <span t-field="rec.name" />
                                    </td>
                                    <td>
                                        <span t-field="rec.description" />
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
