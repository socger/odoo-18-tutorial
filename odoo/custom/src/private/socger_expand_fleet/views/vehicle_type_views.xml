<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_vehicle_type_list" model="ir.ui.view">
        <field name="name">vehicle.type.list</field>
        <field name="model">vehicle.type</field>
        <field name="arch" type="xml">
            <list string="Vehicle Types">
                <field name="name" />
                <field name="seats" />
            </list>
        </field>
    </record>

    <record id="view_vehicle_type_form" model="ir.ui.view">
        <field name="name">vehicle.type.form</field>
        <field name="model">vehicle.type</field>
        <field name="arch" type="xml">
            <form string="Vehicle Type">
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="seats" />
                            <field name="description" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vehicle_type_search" model="ir.ui.view">
        <field name="name">vehicle.type.search</field>
        <field name="model">vehicle.type</field>
        <field name="arch" type="xml">
            <search string="Vehicle Types">
                <field name="name" />
                <field name="description" />
            </search>
        </field>
    </record>

    <record id="action_fleet_vehicle_type" model="ir.actions.act_window">
        <field name="name">Vehicle Types</field>
        <field name="res_model">vehicle.type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new vehicle type
            </p>
        </field>
    </record>
</odoo>
