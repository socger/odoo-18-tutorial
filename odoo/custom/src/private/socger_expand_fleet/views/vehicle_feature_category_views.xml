<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_vehicle_feature_category_list" model="ir.ui.view">
        <field name="name">vehicle.feature.category.list</field>
        <field name="model">vehicle.feature.category</field>
        <field name="arch" type="xml">
            <list string="Vehicle Feature Categories">
                <field name="name" />
                <field name="description" />
            </list>
        </field>
    </record>

    <record id="view_vehicle_feature_category_form" model="ir.ui.view">
        <field name="name">vehicle.feature.category.form</field>
        <field name="model">vehicle.feature.category</field>
        <field name="arch" type="xml">
            <form string="Vehicle Feature Category">
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="description" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_vehicle_feature_category_search" model="ir.ui.view">
        <field name="name">vehicle.feature.category.search</field>
        <field name="model">vehicle.feature.category</field>
        <field name="arch" type="xml">
            <search string="Vehicle Feature Categories">
                <field name="name" />
                <field name="description" />
            </search>
        </field>
    </record>

    <record id="action_vehicle_feature_category" model="ir.actions.act_window">
        <field name="name">Familias - Características de vehículos</field>
        <field name="res_model">vehicle.feature.category</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new vehicle feature category
            </p>
        </field>
    </record>
</odoo>
