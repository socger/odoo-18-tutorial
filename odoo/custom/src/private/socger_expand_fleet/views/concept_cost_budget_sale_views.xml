<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_concept_cost_budget_sale_list" model="ir.ui.view">
        <field name="name">concept.cost.budget.sale.list</field>
        <field name="model">concept.cost.budget.sale</field>
        <field name="arch" type="xml">
            <list string="Concepts">
                <field name="concept_cost_budget_sale_family_id" />
                <field name="name" />
                <field name="description" />
            </list>
        </field>
    </record>

    <record id="view_concept_cost_budget_sale_form" model="ir.ui.view">
        <field name="name">concept.cost.budget.sale.form</field>
        <field name="model">concept.cost.budget.sale</field>
        <field name="arch" type="xml">
            <form string="Concept">
                <sheet>
                    <group>
                        <group>
                            <field name="concept_cost_budget_sale_family_id" />
                            <field name="name" />
                            <field name="description" />
                        </group>
                        <group>
                            <field name="to_cost" />
                            <field name="to_budget" />
                            <field name="to_sale" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_concept_cost_budget_sale_search" model="ir.ui.view">
        <field name="name">concept.cost.budget.sale.search</field>
        <field name="model">concept.cost.budget.sale</field>
        <field name="arch" type="xml">
            <search string="Concepts">
                <field name="concept_cost_budget_sale_family_id" />
                <field name="name" />
                <field name="description" />
            </search>
        </field>
    </record>

    <record id="action_concept_cost_budget_sale" model="ir.actions.act_window">
        <field name="name">Conceptos</field>
        <field name="res_model">concept.cost.budget.sale</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new concept
            </p>
        </field>
    </record>
</odoo>
